<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            style="-fx-background: #eff6ff; -fx-background-color: #eff6ff;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.PsyDashboardController">

    <VBox spacing="0" alignment="TOP_CENTER">
        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-padding: 16 32;">
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="10">
                <Label text="P" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                <Label text="Emonado"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                <Label text="PSY"
                       style="-fx-font-size: 11px; -fx-text-fill: white;
                              -fx-background-color: #3b82f6;
                              -fx-background-radius: 8; -fx-padding: 2 8;"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="16">
                <Button text="Chat"
                        onAction="#openChat"
                        style="-fx-background-color: linear-gradient(to right, #2563eb, #06b6d4); -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: bold; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <VBox alignment="CENTER_RIGHT">
                    <Label text="Bienvenue, Docteur"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Tableau de bord"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>
                <StackPane>
                    <Region style="-fx-background-color: #3b82f6;
                                   -fx-background-radius: 50;
                                   -fx-min-width: 44; -fx-min-height: 44;"/>
                    <Label text="Dr" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </StackPane>
            </HBox>
        </HBox>

        <VBox spacing="32" alignment="TOP_CENTER" style="-fx-padding: 40 32;">
            <VBox alignment="CENTER" spacing="8">
                <Label text="Tableau de bord psychologue" style="-fx-font-size: 18px; -fx-text-fill: #3b82f6;"/>
                <Label fx:id="welcomeLabel" text="Bienvenue Dr."
                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Gerez vos patients et consultations efficacement"
                       style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
            </VBox>

            <HBox spacing="16" alignment="CENTER">
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 16 24;">
                    <Label text="RDV" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <VBox>
                        <Label text="RDV aujourd'hui" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                        <Label text="5 patients" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 16 24;">
                    <Label text="PAT" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <VBox>
                        <Label text="Total patients" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                        <Label text="48 actifs" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 16 24;">
                    <Label text="ANA" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <VBox>
                        <Label text="Analyses" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                        <Label text="12 cette semaine" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                    </VBox>
                </HBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Region style="-fx-background-color: #3b82f6;
                               -fx-background-radius: 4;
                               -fx-min-width: 4; -fx-min-height: 28;"/>
                <Label text="Acces rapide"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            </HBox>

            <FlowPane hgap="20" vgap="20" alignment="CENTER" prefWrapLength="660">
                <VBox onMouseClicked="#goToProfil"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #dbeafe;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="PR" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Profil"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Psychologue"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox onMouseClicked="#goToAnalyses"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #fef3c7;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="AN" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Analyse"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Emotionnelle"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox onMouseClicked="#goToListeRendezVous"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #fce7f3;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="RDV" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Mes"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="RDV"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox onMouseClicked="#goToDisponibilites"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #e0e7ff;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="DISP" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Mes"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Disponibilites"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox onMouseClicked="#goToTypeRdv"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #ccfbf1;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="TYPE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Types"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="RDV"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox onMouseClicked="#goToMedicalManagement"
                      prefWidth="190" prefHeight="180"
                      alignment="CENTER" spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 28; -fx-cursor: hand;">
                    <StackPane>
                        <Region style="-fx-background-color: #dcfce7;
                                       -fx-background-radius: 20;
                                       -fx-min-width: 64; -fx-min-height: 64;"/>
                        <Label text="MED" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Suivi"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Medical"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>
            </FlowPane>

            <Label text="© 2025 Emonado - Espace Psychologue"
                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-padding: 30 0 10 0;"/>
        </VBox>
    </VBox>
</ScrollPane>
