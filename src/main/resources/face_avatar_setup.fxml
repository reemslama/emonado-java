<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.FaceAvatarSetupController"
      alignment="CENTER" spacing="18"
      style="-fx-background-color: linear-gradient(to bottom right, #f0fdf4, #ecfeff); -fx-padding: 40;">

    <VBox alignment="CENTER" spacing="14"
          style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 32; -fx-max-width: 620; -fx-effect: dropshadow(gaussian, rgba(20, 184, 166, 0.12), 24, 0, 0, 8);">

        <Label fx:id="welcomeLabel"
               text="Compte cree"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

        <Label fx:id="subtitleLabel"
               text="Ajoutez un avatar et une photo Face ID, ou ignorez cette etape."
               wrapText="true"
               maxWidth="460"
               style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-alignment: center;"/>

        <StackPane prefWidth="110" prefHeight="110">
            <Region fx:id="avatarPreviewCircle"
                    style="-fx-background-color: linear-gradient(to bottom right, #6ee7b7, #14b8a6); -fx-background-radius: 55;"
                    prefWidth="110" prefHeight="110"/>
            <Label fx:id="initialsLabel"
                   text="PT"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </StackPane>

        <VBox alignment="CENTER" spacing="10">
            <Label text="Choisir un avatar"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <HBox alignment="CENTER" spacing="10">
                <Button text="Menthe" userData="MENTHE" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #dcfce7; -fx-text-fill: #166534; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
                <Button text="Ocean" userData="OCEAN" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #dbeafe; -fx-text-fill: #1d4ed8; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
                <Button text="Soleil" userData="SOLEIL" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #fef3c7; -fx-text-fill: #b45309; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <Button text="Rose" userData="ROSE" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #fce7f3; -fx-text-fill: #be185d; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
                <Button text="Foret" userData="FORET" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #dcfce7; -fx-text-fill: #14532d; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
                <Button text="Lune" userData="LUNE" onAction="#handleAvatarSelection"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-background-radius: 18; -fx-padding: 10 16; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="12"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 18; -fx-max-width: 420;">
            <Label text="Face ID optionnel"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <Label text="Ajoutez une photo visage. Cette version prepare les donnees; le login biometrque webcam pourra etre ajoute ensuite."
                   wrapText="true"
                   maxWidth="360"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-alignment: center;"/>
            <ImageView fx:id="facePreviewImage" fitWidth="150" fitHeight="150" preserveRatio="true"
                       style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 20; -fx-background-radius: 20;"/>
            <Label fx:id="facePhotoLabel" text="Aucune photo choisie." style="-fx-text-fill: #64748b;"/>
            <Button text="Choisir une photo visage" onAction="#chooseFacePhoto"
                    style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 11 18; -fx-font-weight: bold;"/>
        </VBox>

        <Label fx:id="statusLabel"
               wrapText="true"
               maxWidth="420"
               style="-fx-font-size: 13px; -fx-text-fill: #0f766e; -fx-alignment: center;"/>

        <HBox alignment="CENTER" spacing="12">
            <Button text="Enregistrer et continuer" onAction="#saveAndContinue"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 12 22; -fx-font-weight: bold;"/>
            <Button text="Ignorer" onAction="#skip"
                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-background-radius: 20; -fx-padding: 12 22; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>
</VBox>
