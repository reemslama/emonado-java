<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.LoginController"
      styleClass="auth-root">

    <stylesheets>
        <URL value="@/styles/template.css" />
    </stylesheets>

    <VBox spacing="15" styleClass="auth-card">
        <Label text="Connexion" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        <Label text="Veuillez choisir votre role" style="-fx-text-fill: #777; -fx-font-size: 14px;"/>

        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0;">
            <ToggleButton fx:id="rolePatient" text="Patient" styleClass="option-btn"/>
            <ToggleButton fx:id="rolePsy" text="Psychologue" styleClass="option-btn"/>
            <ToggleButton fx:id="roleAdmin" text="Admin" styleClass="option-btn"/>
        </HBox>

        <VBox spacing="10">
            <TextField fx:id="emailField" promptText="Email" styleClass="auth-field"/>
            <PasswordField fx:id="passwordField" promptText="Mot de passe" styleClass="auth-field"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <Hyperlink text="Mot de passe oublie ?"
                       onAction="#handleForgotPassword"
                       style="-fx-text-fill: #e7a83c; -fx-font-weight: bold; -fx-underline: false; -fx-border-color: transparent;"/>
        </HBox>

        <Button text="Se connecter" onAction="#handleLogin" styleClass="primary-action" maxWidth="Infinity"/>

        <HBox spacing="5" alignment="CENTER">
            <Label text="Pas encore de compte ?" style="-fx-text-fill: #777;"/>
            <Hyperlink text="S'inscrire" onAction="#goToRegister"
                       style="-fx-text-fill: #c5df43; -fx-font-weight: bold; -fx-underline: false;"/>
        </HBox>

        <Label fx:id="errorLabel" textFill="red" wrapText="true" alignment="CENTER"/>
    </VBox>
</VBox>
