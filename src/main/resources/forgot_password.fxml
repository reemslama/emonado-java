<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ForgotPasswordController"
      styleClass="auth-root">
    <stylesheets>
        <URL value="@/styles/template.css" />
    </stylesheets>

    <VBox alignment="CENTER_LEFT" spacing="15" styleClass="auth-card">
        <Label text="Mot de passe oublie" styleClass="auth-title"/>
        <Label text="Saisissez votre email pour recevoir le code de verification." styleClass="auth-subtitle" wrapText="true"/>
        <TextField fx:id="emailField" promptText="Votre email" styleClass="auth-field"/>
        <Button text="Envoyer le code" onAction="#sendCode" styleClass="primary-action" maxWidth="Infinity"/>
        <Button text="Retour a la connexion" onAction="#backToLogin" styleClass="secondary-action" maxWidth="Infinity"/>
        <Label fx:id="feedbackLabel" wrapText="true"/>
    </VBox>
</VBox>
