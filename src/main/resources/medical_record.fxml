<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.MedicalRecordController"
            styleClass="background">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #198754; -fx-padding: 16 28;">
            <Label text="EmoNado" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Mon profil" onAction="#goToProfil"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
            <Button text="Retour au tableau de bord" onAction="#returnToDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #e9f7ff; -fx-padding: 15;">
            <VBox spacing="14" style="-fx-padding: 20;">
                <Label fx:id="titleLabel" text="Mon Dossier Medical"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #16324f;"/>

                <HBox spacing="12">
                    <VBox spacing="8" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Mes Informations" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                        <GridPane hgap="10" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="30"/>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="30"/>
                            </columnConstraints>
                            <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Prenom" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="prenomField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                            <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Telephone" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                            <Label text="Sexe" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="sexeField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Date de naissance" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <DatePicker fx:id="birthDatePicker" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                        </GridPane>
                        <Label text="Les informations personnelles sont consultables ici, mais ne peuvent pas etre modifiees depuis le dossier medical."
                               wrapText="true"
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="290"
                          style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Statistiques" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                        <Label text="Consultations"/>
                        <Label fx:id="consultationCountLabel" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Separator/>
                        <Label text="Derniere consultation"/>
                        <Label fx:id="lastConsultationLabel" text="-"/>
                        <Separator/>
                        <Label text="Dossier cree le"/>
                        <Label fx:id="dossierCreationLabel" text="-"/>
                    </VBox>
                </HBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Antecedents Medicaux" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                    <ComboBox fx:id="antecedentTypeCombo" promptText="Choisir le type d'antecedent"/>
                    <TextArea fx:id="antecedentDescriptionArea" wrapText="true" prefRowCount="3"
                              promptText="Decrivez l'antecedent avec des mots et des phrases correctes..."/>
                    <DatePicker fx:id="antecedentDatePicker"/>
                    <Label text="La date de l'antecedent doit etre dans le passe."
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    <HBox spacing="10">
                        <Button fx:id="saveAntecedentButton" text="Ajouter l'antecedent medical" onAction="#handleSaveAntecedent"
                                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button fx:id="cancelAntecedentButton" text="Annuler" onAction="#handleCancelAntecedentEdit"
                                visible="false" managed="false"
                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button fx:id="deleteAntecedentButton" text="Supprimer l'antecedent" onAction="#handleDeleteSelectedAntecedent"
                                visible="false" managed="false"
                                style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    </HBox>
                    <Label text="Liste des antecedents"/>
                    <VBox fx:id="antecedentsContainer" spacing="10"/>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Mes Journaux" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #198754;"/>
                    <VBox fx:id="journalsContainer" spacing="10"/>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Mes Resultats de Tests" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #6f42c1;"/>
                    <VBox fx:id="testResultsContainer" spacing="10"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
