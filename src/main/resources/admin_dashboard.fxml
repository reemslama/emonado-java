<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" prefHeight="700.0" prefWidth="1050.0"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.AdminDashboardController"
            stylesheets="@styles/admin.css">

    <left>
        <VBox spacing="2" prefWidth="250.0"
              style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e293b); -fx-padding: 0;">

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 28 24 24 24;">
                <Circle radius="16" style="-fx-fill: linear-gradient(to bottom right, #3b82f6, #8b5cf6);"/>
                <Label text="EMONADO" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0"/></font>
                </Label>
            </HBox>

            <Label text="MENU PRINCIPAL" style="-fx-padding: 16 24 8 24; -fx-font-size: 10; -fx-text-fill: #475569; -fx-font-weight: bold;"/>

            <Button text="Dashboard" onAction="#showHome" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Patients" onAction="#showPatients" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Psychologues" onAction="#showPsychologues" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Gestion medicale" onAction="#showMedicalManagement" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Questions/Reponses" onAction="#showQuestionsReponses" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Jeu" onAction="#showGameManagement" styleClass="side-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #334155;" opacity="0.4">
                <VBox.margin><Insets left="20" right="20"/></VBox.margin>
            </Separator>

            <Button text="Deconnexion" onAction="#handleLogout" styleClass="logout-button" maxWidth="Infinity" alignment="BASELINE_LEFT">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" style="-fx-background-color: #f8fafc;">

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white; -fx-padding: 18 30; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">

                <Label fx:id="headerTitle" text="Dashboard" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f0f4ff; -fx-padding: 8 16; -fx-background-radius: 20; -fx-border-color: #dbeafe; -fx-border-radius: 20; -fx-border-width: 1;">
                    <Circle radius="5" style="-fx-fill: #22c55e;"/>
                    <Label fx:id="adminEmailLabel" text="admin@emonado.tn"
                           style="-fx-text-fill: #3b82f6; -fx-font-size: 13; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"
                       style="-fx-padding: 28;">
                <VBox alignment="CENTER" spacing="10">
                    <Label text="Bienvenue dans le panneau d'administration"
                           style="-fx-text-fill: #475569; -fx-font-size: 16; -fx-font-weight: bold;"/>
                    <Label text="Selectionnez une section dans le menu pour commencer"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 13;"/>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
