<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="TOP_CENTER" spacing="6.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.ParticipationController"
      stylesheets="@/styles/style.css">

    <padding>
        <Insets top="15.0" right="20.0" bottom="15.0" left="20.0"/>
    </padding>

    <Label text="Jeu enfant" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <ComboBox fx:id="comboJeux" promptText="Sélectionner un jeu" prefWidth="420.0"/>
    <Label fx:id="errorJeu" style="-fx-font-size: 11px;"/>
    <Label fx:id="labelDisponibilite" style="-fx-font-size: 11px;"/>

    <Label fx:id="labelUserNom" text="Participant (Enfant) : " style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

    <Label text="L'enfant choisit une image pour exprimer son état émotionnel :" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
    <TilePane fx:id="imageChoicesPane" hgap="8.0" vgap="8.0" prefColumns="4" prefWidth="920.0"/>
    <Label fx:id="selectedImageLabel" style="-fx-font-size: 11px;"/>
    <Label fx:id="errorChoix" style="-fx-font-size: 11px;"/>

    <VBox spacing="4.0" alignment="TOP_CENTER">
        <Label text="Résultat psychologique :" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
        <Label fx:id="labelInterpretation" style="-fx-text-fill: #2e7d32; -fx-font-size: 15px; -fx-font-weight: bold;" wrapText="true" maxWidth="900.0" textAlignment="CENTER"/>
    </VBox>

    <Label fx:id="msgSuccess" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
    <Label fx:id="errorGlobal" style="-fx-font-size: 12px;"/>


</VBox>
