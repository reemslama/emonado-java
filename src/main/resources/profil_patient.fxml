<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProfilPatientController"
      style="-fx-background-color: rgba(221, 245, 131, 0.27); -fx-background-radius: 25; -fx-padding: 20; -fx-max-width: 450;">

    <HBox alignment="CENTER_LEFT" prefWidth="450">
        <Button text="← Retour" onAction="#returnToDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;"/>
    </HBox>

    <Label fx:id="titleLabel" text="Mon Profil" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <GridPane vgap="10" hgap="10" alignment="CENTER">
        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField" disable="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Téléphone:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Sexe:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="sexeCombo" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="150"/>

        <Label text="Naissance:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="datePicker" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Mdp:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Laisser vide si inchangé" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Mettre à jour" onAction="#handleUpdate" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: #7cb342; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="Supprimer" onAction="#handleDelete" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;"/>
    </HBox>
</VBox>