<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProfilPsyController"
      style="-fx-background-color: rgba(208, 232, 255, 0.27); -fx-background-radius: 25; -fx-padding: 20; -fx-max-width: 500;">

    <HBox alignment="CENTER_LEFT" prefWidth="500">
        <Button text="← Retour" onAction="#returnToDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;"/>
    </HBox>

    <Label fx:id="titleLabel" text="Profil Psychologue" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane vgap="12" hgap="15" alignment="CENTER">
        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Prénom:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email (fixe):" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField" disable="true" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-opacity: 0.7;"/>

        <Label text="Téléphone:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Spécialité:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="specialiteField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Nouveau Mdp:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Laisser vide si inchangé" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button text="Mettre à jour" onAction="#handleUpdate"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="Déconnexion" onAction="#handleLogout"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="Supprimer" onAction="#handleDelete"
                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;"/>
    </HBox>
</VBox>