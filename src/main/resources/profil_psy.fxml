<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ProfilPsyController"
            style="-fx-background: #eff6ff;
                   -fx-background-color: #eff6ff;
                   -fx-border-color: transparent;">
    <content>
        <StackPane alignment="TOP_CENTER" style="-fx-padding: 28;">
            <VBox spacing="24" alignment="TOP_CENTER" maxWidth="700" prefWidth="700" style="-fx-padding: 0;">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: rgba(255,255,255,0.94);
                             -fx-padding: 16 24;
                             -fx-background-radius: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);">
                    <Label text="Emonado"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;
                                  -fx-text-fill: #1e40af; -fx-font-family: 'Segoe UI';"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Donnees securisees"
                           style="-fx-font-size: 12px; -fx-text-fill: #6b7280;
                                  -fx-font-family: 'Segoe UI';"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Button text="Retour au dashboard" onAction="#returnToDashboard"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #6b7280;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: 600;
                                   -fx-cursor: hand;
                                   -fx-font-family: 'Segoe UI';"/>
                </HBox>

                <VBox alignment="CENTER" spacing="18"
                      style="-fx-background-color: white;
                             -fx-background-radius: 24;
                             -fx-padding: 28;
                             -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.15), 25, 0, 0, 8);">

                    <StackPane prefWidth="110" prefHeight="110">
                        <Region style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #1e40af);
                                       -fx-background-radius: 55;
                                       -fx-min-width: 110; -fx-min-height: 110;
                                       -fx-border-color: white; -fx-border-width: 4; -fx-border-radius: 55;"/>
                        <Label text="Dr"
                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </StackPane>

                    <Label fx:id="titleLabel" text="Profil Psychologue"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1f2937; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Gerez vos informations professionnelles"
                           style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;
                                  -fx-font-family: 'Segoe UI';"/>
                </VBox>

                <VBox spacing="20"
                      style="-fx-background-color: white;
                             -fx-background-radius: 24;
                             -fx-padding: 28;
                             -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.12), 20, 0, 0, 6);">

                    <Label text="Informations professionnelles"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;
                                  -fx-text-fill: #1f2937; -fx-font-family: 'Segoe UI';"/>

                    <VBox spacing="6">
                        <Label text="NOM"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="nomField" promptText="Votre nom"
                                   style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #bfdbfe; -fx-padding: 10 14;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="PRENOM"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="prenomField" promptText="Votre prenom"
                                   style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #bfdbfe; -fx-padding: 10 14;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="EMAIL"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="emailField" disable="true"
                                   style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #e5e7eb; -fx-padding: 10 14; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="TELEPHONE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="phoneField" promptText="Votre telephone"
                                   style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #bfdbfe; -fx-padding: 10 14;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="SPECIALITE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="specialiteField" promptText="Votre specialite"
                                   style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #bfdbfe; -fx-padding: 10 14;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="NOUVEAU MOT DE PASSE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #9ca3af; -fx-font-family: 'Segoe UI';"/>
                        <PasswordField fx:id="passwordField" promptText="Laisser vide si inchange"
                                       style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #bfdbfe; -fx-padding: 10 14;"/>
                    </VBox>
                </VBox>

                <HBox spacing="12" alignment="CENTER">
                    <Button text="Mettre a jour" onAction="#handleUpdate"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: linear-gradient(to right, #3b82f6, #6366f1);
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-font-family: 'Segoe UI';
                                   -fx-background-radius: 16;
                                   -fx-padding: 14 24;
                                   -fx-cursor: hand;"/>

                    <Button text="Deconnexion" onAction="#handleLogout"
                            style="-fx-background-color: white;
                                   -fx-text-fill: #6b7280;
                                   -fx-font-size: 13px; -fx-font-weight: 600;
                                   -fx-font-family: 'Segoe UI';
                                   -fx-border-color: #e5e7eb; -fx-border-radius: 16;
                                   -fx-background-radius: 16;
                                   -fx-padding: 14 20;
                                   -fx-cursor: hand;"/>

                    <Button text="Supprimer" onAction="#handleDelete"
                            style="-fx-background-color: white;
                                   -fx-text-fill: #ef4444;
                                   -fx-font-size: 13px; -fx-font-weight: 600;
                                   -fx-font-family: 'Segoe UI';
                                   -fx-border-color: #fecaca; -fx-border-radius: 16;
                                   -fx-background-radius: 16;
                                   -fx-padding: 14 20;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </StackPane>
    </content>
</ScrollPane>
