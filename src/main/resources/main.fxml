<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane fx:controller="org.example.controller.MainController"
            xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/8"
            style="-fx-background-color: #f4f7f6;">

    <!-- ===== NAVBAR MODERNE ===== -->
    <!-- ===== NAVBAR MODERNE ===== -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-padding: 15 40;
                 -fx-background-color: rgba(255,255,255,0.9);
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15,0,0,5);">

            <Label text="🧠 Emonado"
                   style="-fx-text-fill: #198754;
                      -fx-font-size: 22px;
                      -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- ✅ FIX -->
            <Button text="Accueil"
                    onAction="#goToHome"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #555;
                       -fx-font-weight: bold;"/>

            <!-- ✅ FIX -->
            <Button text="Connexion"
                    onAction="#goToLogin"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #555;
                       -fx-font-weight: bold;"/>

            <Button text="S'inscrire"
                    onAction="#goToRegister"
                    style="-fx-background-color: #198754;
                       -fx-text-fill: white;
                       -fx-background-radius: 30;
                       -fx-padding: 8 25;
                       -fx-font-weight: bold;
                       -fx-effect: dropshadow(gaussian, rgba(25,135,84,0.3), 10,0,0,4);"/>
        </HBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <StackPane fx:id="mainContent">
        <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox>

                    <!-- ===== HERO SECTION ===== -->
                    <StackPane prefHeight="750">

                        <!-- Background -->
                        <ImageView fitWidth="1600" fitHeight="750" preserveRatio="false">
                            <image>
                                <Image url="@images/background.png"/>
                            </image>
                        </ImageView>

                        <!-- Dark overlay -->
                        <Region style="-fx-background-color: rgba(0,0,0,0.45);"/>

                        <!-- CONTENT -->
                        <VBox alignment="CENTER" spacing="15"
                              style="-fx-max-width: 500;"
                              StackPane.alignment="CENTER">

                            <Label text="✨ Santé Mentale"
                                   style="-fx-background-color: rgba(255,255,255,0.2);
                                          -fx-text-fill: white;
                                          -fx-padding: 6 15;
                                          -fx-background-radius: 20;
                                          -fx-font-size: 12px;"/>

                            <Label text="Bienvenue sur Emonado"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 36px;
                                          -fx-font-weight: bold;"
                                   wrapText="true"/>

                            <Label text="Évaluez votre état psychologique rapidement et recevez des recommandations personnalisées."
                                   style="-fx-text-fill: rgba(255,255,255,0.8);
                                          -fx-font-size: 14px;"
                                   wrapText="true"/>

                            <HBox spacing="15" alignment="CENTER">

                                <Button text="▶ Commencer"
                                        onAction="#goToRegister"
                                        style="-fx-background-color: #198754;
                                               -fx-text-fill: white;
                                               -fx-font-size: 14px;
                                               -fx-font-weight: bold;
                                               -fx-padding: 10 30;
                                               -fx-background-radius: 50;
                                               -fx-effect: dropshadow(gaussian, rgba(25,135,84,0.4), 15,0,0,5);"/>

                                <Button text="En savoir plus"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: white;
                                               -fx-text-fill: white;
                                               -fx-border-radius: 50;
                                               -fx-padding: 10 25;"/>
                            </HBox>
                        </VBox>
                    </StackPane>

                    <!-- ===== STATS ===== -->
                    <HBox alignment="CENTER" spacing="80"
                          style="-fx-padding: 60;
                                 -fx-background-color: white;">

                        <VBox alignment="CENTER">
                            <Label text="3"
                                   style="-fx-font-size: 40px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Tests Disponibles"
                                   style="-fx-text-fill: #777;"/>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label text="10"
                                   style="-fx-font-size: 40px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Minutes Seulement"
                                   style="-fx-text-fill: #777;"/>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label text="100%"
                                   style="-fx-font-size: 40px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Confidentiel"
                                   style="-fx-text-fill: #777;"/>
                        </VBox>
                    </HBox>

                    <!-- ===== POURQUOI ===== -->
                    <VBox alignment="CENTER" spacing="40"
                          style="-fx-padding: 80 40;
                                 -fx-background-color: #f8f9fa;">

                        <Label text="Pourquoi choisir Emonado ?"
                               style="-fx-font-size: 28px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #198754;"/>

                        <HBox spacing="30" alignment="CENTER">

                            <VBox spacing="10" prefWidth="230"
                                  style="-fx-background-color: white;
                                         -fx-padding: 25;
                                         -fx-background-radius: 15;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,5);">

                                <Label text="✅" style="-fx-font-size: 18px;"/>
                                <Label text="Tests Validés" style="-fx-font-weight: bold;"/>
                                <Label text="Questionnaires scientifiques reconnus."
                                       wrapText="true"/>
                            </VBox>

                            <VBox spacing="10" prefWidth="230"
                                  style="-fx-background-color: white;
                                         -fx-padding: 25;
                                         -fx-background-radius: 15;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,5);">

                                <Label text="🔒" style="-fx-font-size: 18px;"/>
                                <Label text="Confidentiel" style="-fx-font-weight: bold;"/>
                                <Label text="Vos données sont protégées."
                                       wrapText="true"/>
                            </VBox>

                            <VBox spacing="10" prefWidth="230"
                                  style="-fx-background-color: white;
                                         -fx-padding: 25;
                                         -fx-background-radius: 15;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,5);">

                                <Label text="📊" style="-fx-font-size: 18px;"/>
                                <Label text="Suivi personnalisé" style="-fx-font-weight: bold;"/>
                                <Label text="Recommandations adaptées à votre profil."
                                       wrapText="true"/>
                            </VBox>

                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
        </StackPane>
    </center>

</BorderPane>