<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane fx:id="mainContainer"
            fx:controller="org.example.controller.MainController"
            xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/8">

    <top>
        <HBox styleClass="navbar" spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #198754;">
            <Label text="EmoNado" styleClass="brand" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Accueil" styleClass="nav-btn" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Button text="Connexion" styleClass="nav-btn" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Button text="S'inscrire" styleClass="nav-btn" onAction="#goToRegister" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="background">
            <VBox alignment="CENTER" spacing="20">
                <Label text="Bienvenue sur EmoNado" styleClass="title" style="-fx-font-size: 32px; -fx-font-weight: bold;"/>
                <Button text="Commencer" styleClass="btn-custom" onAction="#goToRegister"
                        style="-fx-background-color: #198754; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 20;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
