<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane fx:id="mainContainer"
            fx:controller="org.example.controller.MainController"
            xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/8"
            style="-fx-background-color: #f4f7f6;">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox spacing="25" alignment="CENTER_LEFT"
              style="-fx-padding: 15 40;
                     -fx-background-color: white;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">

            <Label text="Emonado"
                   style="-fx-text-fill: #198754;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS" />

            <Button text="Accueil" onAction="#goToHome"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #495057;
                           -fx-font-weight: bold;"/>

            <Button text="Connexion" onAction="#goToLogin"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #495057;
                           -fx-font-weight: bold;"/>

            <Button text="S'inscrire" onAction="#goToRegister"
                    style="-fx-background-color: #198754;
                           -fx-text-fill: white;
                           -fx-background-radius: 20;
                           -fx-padding: 8 20;
                           -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="0">

                    <!-- ===== HERO ===== -->
                    <StackPane prefHeight="800">

                        <ImageView fitHeight="800" fitWidth="1600" preserveRatio="false">
                            <image>
                                <Image url="@images/background.png"/>
                            </image>
                        </ImageView>

                        <Region style="-fx-background-color: rgba(0,0,0,0.15);"/>

                        <VBox alignment="CENTER" spacing="8"
                              StackPane.alignment="CENTER"
                              style="-fx-background-color: rgba(255,255,255,0.95);
                                     -fx-background-radius: 20;
                                     -fx-padding: 15 20;
                                     -fx-pref-width: 300;
                                     -fx-max-width: 300;
                                     -fx-max-height: 220;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 25, 0.3, 0, 10);">

                            <Label text="🧠 Santé Mentale"
                                   style="-fx-background-color: #e8f5e9;
                                          -fx-text-fill: #198754;
                                          -fx-font-size: 11px;
                                          -fx-font-weight: bold;
                                          -fx-padding: 4 12;
                                          -fx-background-radius: 20;"/>

                            <Label text="Bienvenue sur Emonado"
                                   style="-fx-font-size: 22px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;
                                          -fx-text-alignment: center;"
                                   wrapText="true"/>

                            <Region prefHeight="2" prefWidth="50"
                                    style="-fx-background-color: #198754;"/>

                            <Label text="Évaluez votre état psychologique rapidement et recevez des recommandations."
                                   style="-fx-font-size: 12px;
                                          -fx-text-fill: #555;
                                          -fx-text-alignment: center;"
                                   wrapText="true"/>

                            <Button text="▶ Commencer"
                                    onAction="#goToRegister"
                                    style="-fx-background-color: #198754;
                                           -fx-text-fill: white;
                                           -fx-font-size: 12px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 10 25;
                                           -fx-background-radius: 50;"/>
                        </VBox>

                    </StackPane>

                    <!-- ===== STATS ===== -->
                    <HBox alignment="CENTER" spacing="60"
                          style="-fx-padding: 60 20;
                                 -fx-background-color: white;">

                        <VBox alignment="CENTER">
                            <Label text="3"
                                   style="-fx-font-size: 38px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Tests Disponibles"
                                   style="-fx-text-fill: #6c757d;"/>
                        </VBox>

                        <Separator orientation="VERTICAL" prefHeight="50"/>

                        <VBox alignment="CENTER">
                            <Label text="10"
                                   style="-fx-font-size: 38px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Minutes Seulement"
                                   style="-fx-text-fill: #6c757d;"/>
                        </VBox>

                        <Separator orientation="VERTICAL" prefHeight="50"/>

                        <VBox alignment="CENTER">
                            <Label text="100%"
                                   style="-fx-font-size: 38px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #198754;"/>
                            <Label text="Confidentiel"
                                   style="-fx-text-fill: #6c757d;"/>
                        </VBox>

                    </HBox>

                    <!-- ===== POURQUOI ===== -->
                    <VBox alignment="CENTER" spacing="40"
                          style="-fx-padding: 80 40;
                                 -fx-background-color: #f8f9fa;">

                        <Label text="Pourquoi choisir Emonado ?"
                               style="-fx-font-size: 28px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #198754;"/>

                        <HBox alignment="CENTER" spacing="30">

                            <VBox prefWidth="230" spacing="10"
                                  style="-fx-background-color: white;
                                         -fx-padding: 20;
                                         -fx-background-radius: 15;">
                                <Label text="✅"/>
                                <Label text="Tests Validés"/>
                                <Label text="Questionnaires scientifiques." wrapText="true"/>
                            </VBox>

                            <VBox prefWidth="230" spacing="10"
                                  style="-fx-background-color: white;
                                         -fx-padding: 20;
                                         -fx-background-radius: 15;">
                                <Label text="🔒"/>
                                <Label text="Confidentiel"/>
                                <Label text="Vos données sont sécurisées." wrapText="true"/>
                            </VBox>

                            <VBox prefWidth="230" spacing="10"
                                  style="-fx-background-color: white;
                                         -fx-padding: 20;
                                         -fx-background-radius: 15;">
                                <Label text="📊"/>
                                <Label text="Suivi"/>
                                <Label text="Recommandations personnalisées." wrapText="true"/>
                            </VBox>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>