<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.RegisterController"
      style="-fx-background-color: #f8f8f8; -fx-padding: 50;">

    <stylesheets>
        <URL value="@/styles/template.css"/>
    </stylesheets>

    <VBox spacing="18"
          style="-fx-background-color: white;
                 -fx-background-radius: 25;
                 -fx-padding: 40;
                 -fx-max-width: 500;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <Label text="Créer un compte"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

        <Label text="Remplissez vos informations"
               style="-fx-text-fill: #777; -fx-font-size: 14px;"/>

        <GridPane hgap="12" vgap="12">

            <TextField fx:id="nomField" promptText="Nom"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-background-radius: 15; -fx-padding: 10;
                              -fx-border-color: #ddd; -fx-border-radius: 15;"/>

            <TextField fx:id="prenomField" promptText="Prénom"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       style="-fx-background-radius: 15; -fx-padding: 10;
                              -fx-border-color: #ddd; -fx-border-radius: 15;"/>

            <TextField fx:id="emailField" promptText="Email"
                       GridPane.columnSpan="2" GridPane.rowIndex="1"
                       style="-fx-background-radius: 15; -fx-padding: 10;
                              -fx-border-color: #ddd; -fx-border-radius: 15;"/>

            <PasswordField fx:id="passwordField" promptText="Mot de passe"
                           GridPane.columnSpan="2" GridPane.rowIndex="2"
                           style="-fx-background-radius: 15; -fx-padding: 10;
                                  -fx-border-color: #ddd; -fx-border-radius: 15;"/>

            <Label text="8 caractères min (1 majuscule, 1 chiffre, 1 spécial)"
                   GridPane.columnSpan="2" GridPane.rowIndex="3"
                   style="-fx-text-fill: #999; -fx-font-size: 10px;"/>

            <TextField fx:id="phoneField" promptText="Téléphone"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"
                       style="-fx-background-radius: 15; -fx-padding: 10;
                              -fx-border-color: #ddd; -fx-border-radius: 15;"/>

            <ComboBox fx:id="sexeCombo" promptText="Sexe"
                      GridPane.columnIndex="1" GridPane.rowIndex="4"
                      prefWidth="200"
                      style="-fx-background-radius: 15; -fx-border-color: #ddd;
                             -fx-border-radius: 15;"/>

            <DatePicker fx:id="datePicker" promptText="Date de naissance"
                        GridPane.columnSpan="2" GridPane.rowIndex="5"
                        style="-fx-background-radius: 15; -fx-border-radius: 15;"/>

            <CheckBox fx:id="hasChildCheckBox"
                      text="J'ai un ou plusieurs enfants"
                      onAction="#onHasChildToggled"
                      GridPane.columnSpan="2" GridPane.rowIndex="6"
                      style="-fx-text-fill: #555; -fx-font-size: 13px; -fx-padding: 4 0;"/>

        </GridPane>

        <Button text="Créer mon compte"
                onAction="#handleRegister"
                maxWidth="Infinity"
                style="-fx-background-color: #c5df43;
                       -fx-text-fill: white;
                       -fx-background-radius: 20;
                       -fx-font-weight: bold;
                       -fx-font-size: 16px;
                       -fx-padding: 12;
                       -fx-cursor: hand;"/>

        <HBox spacing="5" alignment="CENTER">
            <Label text="Vous avez déjà un compte ?" style="-fx-text-fill: #777;"/>
            <Hyperlink text="Se connecter" onAction="#goToLogin"
                       style="-fx-text-fill: #c5df43; -fx-font-weight: bold;
                              -fx-underline: false;"/>
        </HBox>

        <Label fx:id="errorLabel" textFill="red" wrapText="true" alignment="CENTER"/>

    </VBox>
</VBox>
