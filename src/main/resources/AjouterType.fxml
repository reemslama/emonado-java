<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.AjouterTypeController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label text="Gestion des Types de RDV" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <VBox spacing="5.0">
            <children>
                <TextField fx:id="txtLibelle" promptText="Entrez le nom du type (ex: Urgent)" />
                <Label fx:id="errorLibelle" text="" style="-fx-text-fill: red; -fx-font-size: 11px;" />
            </children>
        </VBox>

        <Button text="Enregistrer" onAction="#ajouterType" prefWidth="100.0" />
    </children>
</VBox>