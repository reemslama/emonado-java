<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ForgotPasswordCodeController"
      styleClass="auth-root">
    <stylesheets>
        <URL value="@/styles/template.css" />
    </stylesheets>

    <VBox alignment="CENTER_LEFT" spacing="15" styleClass="auth-card">
        <Label text="Verification du code" styleClass="auth-title"/>
        <Label fx:id="emailInfoLabel" text="Code envoye" styleClass="auth-subtitle" wrapText="true"/>
        <TextField fx:id="codeField" promptText="Code a 6 chiffres" styleClass="auth-field"/>
        <Button text="Verifier le code" onAction="#verifyCode" styleClass="primary-action" maxWidth="Infinity"/>
        <Button text="Retour" onAction="#back" styleClass="secondary-action" maxWidth="Infinity"/>
        <Label fx:id="feedbackLabel" wrapText="true"/>
    </VBox>
</VBox>
