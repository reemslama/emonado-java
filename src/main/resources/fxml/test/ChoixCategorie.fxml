<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.test.ChoixCategorieController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f0f4f8; -fx-padding: 60;">

    <Label text="🧠 Test de Santé Mentale"
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Ces tests sont basés sur des échelles cliniques reconnues (PSS, PHQ-9, GAD-7)"
           wrapText="true"
           alignment="CENTER"
           style="-fx-font-size: 13px; -fx-text-fill: #95a5a6; -fx-max-width: 500;"/>

    <Label text="Choisissez un test à passer :"
           style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d; -fx-padding: 10 0 0 0;"/>

    <Button fx:id="btnStress"
            text="😰 Test Stress"
            onAction="#choisirStress"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16px; -fx-pref-width: 300; -fx-pref-height: 55; -fx-background-radius: 10;"/>

    <Button fx:id="btnDepression"
            text="😔 Test Dépression"
            onAction="#choisirDepression"
            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 16px; -fx-pref-width: 300; -fx-pref-height: 55; -fx-background-radius: 10;"/>

    <Button fx:id="btnAnxiete"
            text="😟 Test Anxiété"
            onAction="#choisirAnxiete"
            style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-size: 16px; -fx-pref-width: 300; -fx-pref-height: 55; -fx-background-radius: 10;"/>

    <Button fx:id="btnIQ"
            text="🧩 Test IQ"
            onAction="#choisirIQ"
            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 16px; -fx-pref-width: 300; -fx-pref-height: 55; -fx-background-radius: 10;"/>

    <Label text="⚠ Ces tests ne remplacent pas un avis médical professionnel."
           wrapText="true"
           alignment="CENTER"
           style="-fx-font-size: 12px; -fx-text-fill: #e74c3c; -fx-padding: 15 0 0 0; -fx-max-width: 450;"/>

</VBox>