<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.ResultatController"
      prefWidth="960" prefHeight="640"
      style="-fx-background-color: #EAF4F8; -fx-font-family: 'Segoe UI';">

    <!-- ===== EN-TÊTE ===== -->
    <VBox alignment="CENTER" spacing="6" style="-fx-padding: 16 0 0 0;">
        <Label text="VOTRE RÉSULTAT"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

        <HBox fx:id="pillNiveau" alignment="CENTER" spacing="10" maxWidth="320"
              style="-fx-background-color: #f39c1222;
                     -fx-background-radius: 20;
                     -fx-border-radius: 20;
                     -fx-border-color: #f39c12;
                     -fx-border-width: 1.5;
                     -fx-padding: 6 20 6 20;">
            <Circle fx:id="dotNiveau" radius="8" fill="#f39c12"/>
            <VBox alignment="CENTER" spacing="1">
                <Label fx:id="lblCategorie" text="DÉPRESSION"
                       style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;"/>
                <Label fx:id="lblNiveau" text="SIGNES MODÉRÉS"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
            </VBox>
            <Circle radius="8" fill="#f39c12"/>
        </HBox>
    </VBox>

    <!-- ===== ZONE CENTRALE ===== -->
    <HBox spacing="14" style="-fx-padding: 10 16 0 16;" VBox.vgrow="ALWAYS">

        <!-- COLONNE GAUCHE : Jauges -->
        <VBox spacing="12" prefWidth="200" minWidth="180"
              style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <Label text="Dimensions"
                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;"/>
            <VBox spacing="5">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="📊" style="-fx-font-size: 12px;"/>
                    <Label text="ÉMOTIONNEL" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblEmo" text="7/10" style="-fx-font-size: 11px; -fx-text-fill: #3498db; -fx-font-weight: bold;"/>
                </HBox>
                <Canvas fx:id="barEmo" width="168" height="10"/>
            </VBox>
            <VBox spacing="5">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="🌿" style="-fx-font-size: 12px;"/>
                    <Label text="PHYSIQUE" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblPhy" text="3/10" style="-fx-font-size: 11px; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                </HBox>
                <Canvas fx:id="barPhy" width="168" height="10"/>
            </VBox>
            <VBox spacing="5">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="🧠" style="-fx-font-size: 12px;"/>
                    <Label text="COGNITIF" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCog" text="6/10" style="-fx-font-size: 11px; -fx-text-fill: #f1c40f; -fx-font-weight: bold;"/>
                </HBox>
                <Canvas fx:id="barCog" width="168" height="10"/>
            </VBox>
        </VBox>

        <!-- COLONNE CENTRE -->
        <VBox spacing="0" alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-padding: 20 16 16 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <StackPane prefWidth="260" prefHeight="160" minHeight="160" alignment="CENTER">
                <Canvas fx:id="canvasScore" width="260" height="160" StackPane.alignment="CENTER"/>
                <Label fx:id="lblScore" text="-- / --"
                       StackPane.alignment="CENTER" translateY="20"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            </StackPane>
            <Label fx:id="lblDescription" text=""
                   wrapText="true" textAlignment="CENTER" alignment="CENTER" maxWidth="340"
                   style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-padding: 8 0 4 0;"/>
            <StackPane prefWidth="60" prefHeight="130" minHeight="130" alignment="CENTER"
                       style="-fx-padding: 0 0 8 0;">
                <Canvas fx:id="canvasThermo" width="60" height="130" StackPane.alignment="CENTER"/>
            </StackPane>
            <HBox spacing="12" alignment="CENTER">
                <Button text="💬  Pensez à en parler" onAction="#ouvrirConsultation"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 9 20; -fx-cursor: hand;"/>
                <Button text="📖  Ouvrir le Journal" onAction="#ouvrirJournal"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 9 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- COLONNE DROITE -->
        <VBox spacing="10" prefWidth="230" minWidth="210">

            <!-- Thèmes -->
            <VBox fx:id="vboxThemes" spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 16;
                         -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="📋  Analyse par thème :"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="💤" style="-fx-font-size: 13px;"/>
                    <Label text="Sommeil → 6 pts" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="😊" style="-fx-font-size: 13px;"/>
                    <Label text="Humeur → 2 pts" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="⚡" style="-fx-font-size: 13px;"/>
                    <Label text="Énergie → 1 pt" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                </HBox>
            </VBox>

            <!-- Analyse IA -->
            <VBox fx:id="cardAnalyseIA" spacing="8" VBox.vgrow="ALWAYS"
                  visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 16;
                         -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="🤖" style="-fx-font-size: 13px;"/>
                    <Label text="Analyse IA"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                </HBox>
                <Label fx:id="lblStatutAnalyse" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #3498db;"/>
                <Label fx:id="lblAnalyseIA" text=""
                       wrapText="true"
                       prefWidth="196"
                       VBox.vgrow="ALWAYS"
                       style="-fx-font-size: 11px; -fx-text-fill: #444; -fx-padding: 2 0;"/>
            </VBox>

        </VBox>
    </HBox>

    <!-- ===== BARRE BAS ===== -->
    <HBox spacing="0" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 8 0 8 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 6, 0, 0, -2);"
          VBox.vgrow="NEVER">

        <Button onAction="#ouvrirJournal" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Ouvrir Journal"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: #ECF0F1; -fx-border-width: 0 1 0 0;
                       -fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="📅" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

        <Button onAction="#ouvrirConsultation" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Prendre Consultation"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: #ECF0F1; -fx-border-width: 0 1 0 0;
                       -fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="🤝" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

        <Button onAction="#refaire" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Recommencer"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: #ECF0F1; -fx-border-width: 0 1 0 0;
                       -fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="🔄" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

        <Button onAction="#accueil" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Accueil"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: #ECF0F1; -fx-border-width: 0 1 0 0;
                       -fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="🏠" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

        <!-- ══ NOUVEAU : Exporter PDF ══ -->
        <Button onAction="#exporterPDF" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Exporter PDF"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: #ECF0F1; -fx-border-width: 0 1 0 0;
                       -fx-font-size: 11px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="📄" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

        <!-- ══ NOUVEAU : Tableau de bord ══ -->
        <Button onAction="#ouvrirDashboard" prefWidth="160" prefHeight="56"
                contentDisplay="TOP" text="Tableau de bord"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-font-size: 11px; -fx-text-fill: #3498db; -fx-font-weight: bold;
                       -fx-graphic-text-gap: 3;">
            <graphic>
                <Label text="📊" style="-fx-font-size: 20px;" mouseTransparent="true"/>
            </graphic>
        </Button>

    </HBox>

</VBox>
