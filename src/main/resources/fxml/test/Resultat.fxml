<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ResultatController"
            fitToWidth="true"
            style="-fx-background: #f5f7f2; -fx-background-color: #f5f7f2;">

    <VBox alignment="TOP_CENTER" spacing="0"
          style="-fx-background-color: #f5f7f2; -fx-padding: 40 60 40 60;">

        <!-- HEADER -->
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 28 0;">
            <Label text="Résultat du test"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
            <HBox alignment="CENTER" spacing="6">
                <Circle fx:id="dotCategorie" radius="4"/>
                <Label fx:id="lblCategorie" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #8a9bb0;"/>
            </HBox>
        </VBox>

        <!-- MAIN CARD -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-border-radius: 16; -fx-border-color: #e8edf2; -fx-border-width: 1;
                     -fx-padding: 32 36 28 36;" spacing="0" maxWidth="720">

            <!-- SCORE ROW -->
            <HBox spacing="32" alignment="CENTER_LEFT">

                <!-- THERMOMETRE -->
                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 8 0 0;">
                    <Label text="NIVEAU"
                           style="-fx-font-size: 10px; -fx-text-fill: #aab4bf; -fx-font-weight: bold;"/>
                    <Canvas fx:id="canvasThermo" width="52" height="200"/>
                    <Label text="STRESS"
                           style="-fx-font-size: 10px; -fx-text-fill: #aab4bf; -fx-font-weight: bold;"/>
                </VBox>

                <!-- LÉGENDE ZONES -->
                <VBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 10 16 0 0;" prefHeight="200">
                    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 0 0 46 0;">
                        <Circle radius="4" fill="#e74c3c"/>
                        <Label text="Élevé · 24–30"
                               style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 0 0 46 0;">
                        <Circle radius="4" fill="#f39c12"/>
                        <Label text="Modéré · 13–23"
                               style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Circle radius="4" fill="#27ae60"/>
                        <Label text="Faible · 0–12"
                               style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0;"/>
                    </HBox>
                </VBox>

                <!-- SCORE + NIVEAU -->
                <VBox spacing="10" alignment="TOP_LEFT">
                    <Label fx:id="lblScore" text=""
                           style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    <Label text="sur 30 points"
                           style="-fx-font-size: 13px; -fx-text-fill: #8a9bb0; -fx-padding: -10 0 4 0;"/>
                    <HBox fx:id="pillNiveau" alignment="CENTER_LEFT" spacing="6"
                          style="-fx-background-radius: 20; -fx-padding: 6 14 6 14;">
                        <Circle fx:id="dotNiveau" radius="4"/>
                        <Label fx:id="lblNiveau" text=""
                               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label fx:id="lblDescription" text="" wrapText="true"
                           maxWidth="280"
                           style="-fx-font-size: 13px; -fx-text-fill: #6b7a8d; -fx-line-spacing: 2;"/>
                </VBox>
            </HBox>

            <!-- SÉPARATEUR -->
            <Separator style="-fx-padding: 20 0 0 0;"/>
            <Region prefHeight="20"/>

            <!-- DIMENSIONS -->
            <Label text="ANALYSE PAR DIMENSION"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #aab4bf; -fx-padding: 0 0 12 0;"/>
            <HBox spacing="12">
                <VBox fx:id="cardEmotionnel" alignment="CENTER" spacing="6"
                      style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 14 20 14 20;"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label fx:id="lblEmo" text="7/10"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    <Canvas fx:id="barEmo" width="100" height="4"/>
                    <Label text="Émotionnel"
                           style="-fx-font-size: 12px; -fx-text-fill: #8a9bb0;"/>
                </VBox>
                <VBox fx:id="cardPhysique" alignment="CENTER" spacing="6"
                      style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 14 20 14 20;"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label fx:id="lblPhy" text="5/10"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    <Canvas fx:id="barPhy" width="100" height="4"/>
                    <Label text="Physique"
                           style="-fx-font-size: 12px; -fx-text-fill: #8a9bb0;"/>
                </VBox>
                <VBox fx:id="cardCognitif" alignment="CENTER" spacing="6"
                      style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 14 20 14 20;"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label fx:id="lblCog" text="7/10"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    <Canvas fx:id="barCog" width="100" height="4"/>
                    <Label text="Cognitif"
                           style="-fx-font-size: 12px; -fx-text-fill: #8a9bb0;"/>
                </VBox>
            </HBox>

            <Region prefHeight="20"/>

            <!-- RECOMMANDATIONS -->
            <Label text="RECOMMANDATIONS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #aab4bf; -fx-padding: 0 0 12 0;"/>
            <HBox spacing="10">
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #e8edf2; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 12 14 12 14;" spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="⏱" style="-fx-font-size: 14px;"/>
                        <Label text="Pause active"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    </HBox>
                    <Label text="5 min toutes les heures pour décompresser"
                           wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0; -fx-line-spacing: 1;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #e8edf2; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 12 14 12 14;" spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🌬" style="-fx-font-size: 14px;"/>
                        <Label text="Respiration"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    </HBox>
                    <Label text="Cohérence cardiaque 3×/jour"
                           wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0; -fx-line-spacing: 1;"/>
                </VBox>
                <VBox fx:id="cardJournal"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #e8edf2; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 12 14 12 14; -fx-cursor: hand;" spacing="6"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      onMouseClicked="#ouvrirJournal">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📓" style="-fx-font-size: 14px;"/>
                        <Label text="Journal"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1e2d3d;"/>
                    </HBox>
                    <Label text="Écrire ses pensées le soir"
                           wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #8a9bb0; -fx-line-spacing: 1;"/>
                </VBox>
            </HBox>
        </VBox>

        <Region prefHeight="16"/>

        <!-- BANNIÈRE CONSULTATION (visible si stress élevé) -->
        <VBox fx:id="banniereConsultation" managed="false" visible="false"
              maxWidth="720"
              style="-fx-background-color: #fff5f5; -fx-background-radius: 12;
                     -fx-border-color: #f5c0c0; -fx-border-radius: 12; -fx-border-width: 1;
                     -fx-padding: 16 20 16 20;" spacing="6">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="⚠" style="-fx-font-size: 16px;"/>
                <VBox spacing="2">
                    <Label text="Niveau élevé détecté"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                    <Label text="Nous vous recommandons de consulter un professionnel dès que possible."
                           wrapText="true" maxWidth="580"
                           style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"/>
                </VBox>
            </HBox>
            <Button text="Réserver une consultation →"
                    onAction="#ouvrirConsultation"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 20 10 20;"/>
        </VBox>

        <!-- SUGGESTION CONSULTATION (visible si stress modéré) -->
        <VBox fx:id="suggestionConsultation" managed="false" visible="false"
              maxWidth="720"
              style="-fx-background-color: #fffbf0; -fx-background-radius: 12;
                     -fx-border-color: #fce0a0; -fx-border-radius: 12; -fx-border-width: 1;
                     -fx-padding: 16 20 16 20;" spacing="6">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="💡" style="-fx-font-size: 16px;"/>
                <Label text="Un accompagnement préventif peut être bénéfique."
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #b07d0a;"/>
            </HBox>
            <Button text="Voir les consultations disponibles →"
                    onAction="#ouvrirConsultation"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 20 10 20;"/>
        </VBox>

        <Region prefHeight="20"/>

        <!-- BOUTONS BAS -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="↺  Refaire le test"
                    onAction="#refaire"
                    style="-fx-background-color: transparent; -fx-text-fill: #4a5568;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-color: #d1d9e0; -fx-border-radius: 8;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 22 10 22;"/>
            <Button text="⌂  Accueil"
                    onAction="#accueil"
                    style="-fx-background-color: transparent; -fx-text-fill: #4a5568;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-color: #d1d9e0; -fx-border-radius: 8;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 22 10 22;"/>
        </HBox>

    </VBox>
</ScrollPane>
