<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #ffffff;"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.PasserTestController">

    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
            <children>
                <!-- Progress bar only - thin orange line like unobravo -->
                <ProgressBar fx:id="progressBar"
                             prefHeight="4.0"
                             prefWidth="1200.0"
                             progress="0.1"
                             style="-fx-accent: #e8745a; -fx-background-color: #f0ece8; -fx-background-radius: 0; -fx-effect: none;" />

                <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 18 48 14 48;">
                    <children>
                        <Label fx:id="lblTitre" text="" style="-fx-text-fill: transparent; -fx-font-size: 0;" />
                        <Label fx:id="lblProgression" text="Question 1 / 10"
                               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_LEFT" spacing="28.0"
              style="-fx-padding: 48 48 24 48; -fx-background-color: #ffffff;">
            <children>

                <!-- Question card -->
                <VBox alignment="TOP_LEFT" spacing="10.0"
                      style="-fx-background-color: #ffffff;">
                    <children>
                        <Label fx:id="lblQuestion"
                               text="Question ici..."
                               wrapText="true"
                               style="-fx-text-fill: #1a1a1a; -fx-font-size: 26px; -fx-font-weight: bold; -fx-line-spacing: 4;">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>

                        <Label fx:id="lblErreur"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-padding: 4 0 0 0;" />
                    </children>
                </VBox>

                <!-- Options scroll area -->
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                            prefViewportHeight="480.0">
                    <content>
                        <VBox fx:id="vboxReponses" spacing="12.0"
                              style="-fx-padding: 4 0 0 0;" />
                    </content>
                </ScrollPane>

            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="16.0"
              style="-fx-background-color: #fafaf8; -fx-padding: 18 48 18 48; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
            <children>

                <Button fx:id="btnRetour"
                        onAction="#retour"
                        text="← Retour"
                        visible="false"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #888888;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-padding: 12 24;
                               -fx-background-radius: 50;
                               -fx-border-color: #e0dbd6;
                               -fx-border-radius: 50;
                               -fx-border-width: 1.5;
                               -fx-cursor: hand;" />

                <Button fx:id="btnSuivant"
                        onAction="#suivant"
                        text="Continuer  ›"
                        style="-fx-background-color: #e8745a;
                               -fx-text-fill: white;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-padding: 13 32;
                               -fx-background-radius: 50;
                               -fx-cursor: hand;
                               -fx-effect: none;">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Button>

            </children>
        </HBox>
    </bottom>

</BorderPane>
